generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  password   String
  roleLevel  Int      @default(1)
  isApproved Boolean  @default(false)
  leagueId   Int?
  league     League?  @relation(fields: [leagueId], references: [id])
  createdAt  DateTime @default(now())
}

model League {
  id          Int      @id @default(autoincrement())
  name        String
  fullName    String?
  location    String?
  description String?
  isActive    Boolean  @default(true)
  seasons     Season[]
  users       User[]
  createdAt   DateTime @default(now())
}

model Team {
  id          Int           @id @default(autoincrement())
  name        String
  seasonId    Int
  season      Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeGames   Game[]        @relation("HomeTeam")
  awayGames   Game[]        @relation("AwayTeam")
  rosterSlots RosterSlot[]
  lineups     LineupEntry[] 
  createdAt   DateTime      @default(now())
}

model Player {
  id             Int           @id @default(autoincrement())
  name           String
  rosterSlots    RosterSlot[]
  atBats         AtBat[]       @relation("Batter")
  pitchedAtBats  AtBat[]       @relation("Pitcher")
  lineups        LineupEntry[] 
  createdAt      DateTime      @default(now())
}

model RosterSlot {
  id       Int    @id @default(autoincrement())
  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teamId   Int
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId Int
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId, playerId])
}

model Season {
  id                   Int          @id @default(autoincrement())
  name                 String
  leagueId             Int
  league               League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  status               String       @default("ACTIVE") 
  inningsPerGame       Int          @default(4)
  eraStandard          Int          @default(4)
  balls                Int          @default(4)
  strikes              Int          @default(3)
  outs                 Int          @default(3)
  isSpeedRestricted    Boolean      @default(false)
  speedLimit           Int          @default(60) 
  isBaserunning        Boolean      @default(true)
  cleanHitRule         Boolean      @default(true)
  ghostRunner          Boolean      @default(false)
  dpWithoutRunners     Boolean      @default(false)
  dpKeepsRunners       Boolean      @default(false)
  mercyRule            Int          @default(10)
  mercyRulePerInning   Int          @default(0)
  mercyRuleInningApply Int          @default(3) 
  unlimitedLastInning  Boolean      @default(false) 
  games                Game[]
  teams                Team[]   
  rosterSlots          RosterSlot[]
  createdAt            DateTime     @default(now())
}

model Game {
  id                   Int           @id @default(autoincrement())
  seasonId             Int
  season               Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeamId           Int
  homeTeam             Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId           Int
  awayTeam             Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  scheduledAt          DateTime
  status               String        @default("SCHEDULED")
  homeScore            Int           @default(0)
  awayScore            Int           @default(0)
  location             String?
  liveState            String?       
  currentHomePitcherId Int?
  currentAwayPitcherId Int?
  inningScores         InningScore[]
  atBats               AtBat[]
  lineups              LineupEntry[] 
  createdAt            DateTime      @default(now())
}

model InningScore {
  id         Int     @id @default(autoincrement())
  gameId     Int
  game       Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  inning     Int
  homeRuns   Int     @default(0)
  awayRuns   Int     @default(0)
  isComplete Boolean @default(false)
}

model AtBat {
  id          Int      @id @default(autoincrement())
  gameId      Int
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  batterId    Int
  batter      Player   @relation("Batter", fields: [batterId], references: [id])
  pitcherId   Int
  pitcher     Player   @relation("Pitcher", fields: [pitcherId], references: [id])
  inning      Int      @default(1)
  isTopInning Boolean  @default(true) 
  result      String?
  runsScored  Int      @default(0)
  rbi         Int      @default(0)
  balls       Int      @default(0)
  strikes     Int      @default(0)
  outs        Int      @default(0)
  createdAt   DateTime @default(now())
}

model LineupEntry {
  id           Int     @id @default(autoincrement())
  gameId       Int
  game         Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId       Int
  team         Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId     Int
  player       Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  battingOrder Int
  isPitcher    Boolean @default(false)
}