generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int                @id @default(autoincrement())
  email          String             @unique
  name           String?
  password       String
  isGlobalAdmin  Boolean            @default(false) // Replaces Level 3
  memberships    LeagueMembership[]
  createdAt      DateTime           @default(now())
}

model League {
  id          Int                @id @default(autoincrement())
  name        String
  fullName    String?
  location    String?
  description String?
  isActive    Boolean            @default(true)
  seasons     Season[]
  memberships LeagueMembership[] 
  teams       Team[]             
  createdAt   DateTime           @default(now())
}

model LeagueMembership {
  id         Int     @id @default(autoincrement())
  userId     Int
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  leagueId   Int
  league     League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roleLevel  Int     @default(1) // 1 = Scorekeeper, 2 = Commissioner
  isApproved Boolean @default(false)

  @@unique([userId, leagueId])
}

model Team {
  id          Int           @id @default(autoincrement())
  name        String
  
  // CHANGED: Teams now belong to the Master League Pool
  leagueId    Int           
  league      League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  isActive    Boolean       @default(true) // <-- NEW FLAG
  // CHANGED: Teams can now be toggled on/off in multiple seasons
  seasons     Season[]      
  
  homeGames   Game[]        @relation("HomeTeam")
  awayGames   Game[]        @relation("AwayTeam")
  rosterSlots RosterSlot[]
  lineups     LineupEntry[] 
  createdAt   DateTime      @default(now())
}

model Player {
  id             Int           @id @default(autoincrement())
  name           String
  leagueId       Int?
  rosterSlots    RosterSlot[]
  atBats         AtBat[]       @relation("Batter")
  pitchedAtBats  AtBat[]       @relation("Pitcher")
  lineups        LineupEntry[] 
  createdAt      DateTime      @default(now())
}

model RosterSlot {
  id       Int    @id @default(autoincrement())
  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teamId   Int
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId Int
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId, playerId])
}

model Season {
  id                   Int          @id @default(autoincrement())
  events              Event[]
  name                 String
  leagueId             Int
  league               League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  status               String       @default("ACTIVE") 
  inningsPerGame       Int          @default(4)
  isTournament         Boolean      @default(false)
  playoffInnings       Int?         @default(5)
  eraStandard          Int          @default(4)
  balls                Int          @default(4)
  strikes              Int          @default(3)
  outs                 Int          @default(3)
  isSpeedRestricted    Boolean      @default(false)
  speedLimit           Int          @default(60) 
  isBaserunning        Boolean      @default(true)
  cleanHitRule         Boolean      @default(true)
  ghostRunner          Boolean      @default(false)
  dpWithoutRunners     Boolean      @default(false)
  dpKeepsRunners       Boolean      @default(false)
  mercyRule            Int          @default(10)
  mercyRulePerInning   Int          @default(0)
  mercyRuleInningApply Int          @default(3) 
  unlimitedLastInning  Boolean      @default(false) 
  allowPitcherReentry  Boolean      @default(true) // <-- Added here
  maxDh                Int          @default(1)
  minBatters           Int          @default(0) // 0 = Off
  games                Game[]
  teams                Team[]   
  rosterSlots          RosterSlot[]
  createdAt            DateTime     @default(now())
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "Saturday Shootout"
  status      String   @default("UPCOMING") // UPCOMING, ACTIVE, COMPLETED
  seasonId    Int
  season      Season   @relation(fields: [seasonId], references: [id])
  games       Game[]   // Games belonging to this specific event
  createdAt   DateTime @default(now())
}

model Game {
  id                   Int           @id @default(autoincrement())
  seasonId             Int
  season               Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeamId           Int
  homeTeam             Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId           Int
  awayTeam             Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  scheduledAt          DateTime
  status               String        @default("SCHEDULED")
  homeScore            Int           @default(0)
  awayScore            Int           @default(0)
  location             String?
  liveState            String?
  isPlayoff            Boolean       @default(false)     
  currentHomePitcherId Int?
  currentAwayPitcherId Int?
  inningScores         InningScore[]
  atBats               AtBat[]
  lineups              LineupEntry[] 
  createdAt            DateTime      @default(now())
  fieldNumber    Int?
  eventId     Int?     // Optional: regular season games might not have an event
  event       Event?   @relation(fields: [eventId], references: [id])
}

model InningScore {
  id         Int     @id @default(autoincrement())
  gameId     Int
  game       Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  inning     Int
  homeRuns   Int     @default(0)
  awayRuns   Int     @default(0)
  isComplete Boolean @default(false)
}

model AtBat {
  id             Int      @id @default(autoincrement())
  gameId         Int
  game           Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  batterId       Int
  batter         Player   @relation("Batter", fields: [batterId], references: [id])
  pitcherId      Int
  pitcher        Player   @relation("Pitcher", fields: [pitcherId], references: [id])
  runAttribution String?
  slot           Int
  inning         Int      @default(1)
  isTopInning    Boolean  @default(true) 
  result         String?
  runsScored     Int      @default(0)
  rbi            Int      @default(0)
  balls          Int      @default(0)
  strikes        Int      @default(0)
  outs           Int      @default(0)
  createdAt      DateTime @default(now())
  runnersOn   Int      @default(0) // 0, 1, 2, or 3 runners
  outsAtStart Int      @default(0) // 0, 1, or 2 outs
}

model LineupEntry {
  id           Int     @id @default(autoincrement())
  gameId       Int
  game         Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId       Int
  team         Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId     Int
  player       Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  battingOrder Int
  isPitcher    Boolean @default(false)
  position     String  @default("Fielder") // <-- Added here
}