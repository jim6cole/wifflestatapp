generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  name              String?
  password          String
  isGlobalAdmin     Boolean            @default(false)
  memberships       LeagueMembership[]
  emailVerified     DateTime?
  resetToken        String?            @unique
  resetTokenExpiry  DateTime?
  verificationToken String?            @unique
  createdAt         DateTime           @default(now())
}

model League {
  id            Int                @id @default(autoincrement())
  name          String
  fullName      String?
  shortName     String?
  location      String?
  description   String?
  isActive      Boolean            @default(true)
  seasons       Season[]
  memberships   LeagueMembership[]
  teams         Team[]
  emailVerified DateTime?
  createdAt     DateTime           @default(now())
}

model LeagueMembership {
  id         Int     @id @default(autoincrement())
  userId     Int
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  leagueId   Int
  league     League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roleLevel  Int     @default(1)
  isApproved Boolean @default(false)

  @@unique([userId, leagueId])
}

model Team {
  id          Int           @id @default(autoincrement())
  name        String
  leagueId    Int
  league      League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  isActive    Boolean       @default(true)
  seasons     Season[]
  homeGames   Game[]        @relation("HomeTeam")
  awayGames   Game[]        @relation("AwayTeam")
  rosterSlots RosterSlot[]
  lineups     LineupEntry[]
  manualStats ManualStatLine[]
  createdAt   DateTime      @default(now())
}

model Player {
  id              Int              @id @default(autoincrement())
  name            String
  leagueId        Int?
  rosterSlots     RosterSlot[]
  atBats          AtBat[]          @relation("Batter")
  pitchedAtBats   AtBat[]          @relation("Pitcher")
  lineups         LineupEntry[]
  manualStats     ManualStatLine[] 
  historicalStats HistoricalStat[] 
  createdAt       DateTime         @default(now())
}

model RosterSlot {
  id       Int    @id @default(autoincrement())
  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teamId   Int
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId Int
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId, playerId])
}

model Season {
  id                   Int          @id @default(autoincrement())
  events               Event[]
  name                 String
  leagueId             Int
  league               League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  status               String       @default("ACTIVE")
  inningsPerGame       Int          @default(4)
  isTournament         Boolean      @default(false)
  playoffInnings       Int?         @default(5)
  eraStandard          Int          @default(4)
  balls                Int          @default(4)
  strikes              Int          @default(3)
  outs                 Int          @default(3)
  isSpeedRestricted    Boolean      @default(false)
  speedLimit           Int          @default(60)
  isBaserunning        Boolean      @default(true)
  cleanHitRule         Boolean      @default(true)
  ghostRunner          Boolean      @default(false)
  dpWithoutRunners     Boolean      @default(false)
  dpKeepsRunners       Boolean      @default(false)
  mercyRule            Int          @default(10)
  mercyRulePerInning   Int          @default(0)
  mercyRuleInningApply Int          @default(3)
  unlimitedLastInning  Boolean      @default(false)
  allowPitcherReentry  Boolean      @default(true)
  maxDh                Int          @default(1)
  minBatters           Int          @default(0)
  games                Game[]
  teams                Team[]
  rosterSlots          RosterSlot[]
  createdAt            DateTime     @default(now())
}

model Event {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("UPCOMING")
  seasonId  Int
  season    Season   @relation(fields: [seasonId], references: [id])
  games     Game[]
  createdAt DateTime @default(now())
}

model Game {
  id                   Int              @id @default(autoincrement())
  seasonId             Int
  season               Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeTeamId           Int
  homeTeam             Team             @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId           Int
  awayTeam             Team             @relation("AwayTeam", fields: [awayTeamId], references: [id])
  scheduledAt          DateTime
  status               String           @default("SCHEDULED")
  homeScore            Int              @default(0)
  awayScore            Int              @default(0)
  location             String?
  liveState            String?
  isPlayoff            Boolean          @default(false)
  currentHomePitcherId Int?
  currentAwayPitcherId Int?
  inningScores         InningScore[]
  atBats               AtBat[]
  lineups              LineupEntry[]
  manualStats          ManualStatLine[]
  createdAt            DateTime         @default(now())
  fieldNumber          Int?
  eventId              Int?
  event                Event?           @relation(fields: [eventId], references: [id])
}

model InningScore {
  id         Int     @id @default(autoincrement())
  gameId     Int
  game       Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  inning     Int
  homeRuns   Int     @default(0)
  awayRuns   Int     @default(0)
  isComplete Boolean @default(false)
}

model AtBat {
  id             Int      @id @default(autoincrement())
  gameId         Int
  game           Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  batterId       Int
  batter         Player   @relation("Batter", fields: [batterId], references: [id])
  pitcherId      Int
  pitcher        Player   @relation("Pitcher", fields: [pitcherId], references: [id])
  runAttribution String?
  slot           Int
  inning         Int      @default(1)
  isTopInning    Boolean  @default(true)
  result         String?
  runsScored     Int      @default(0)
  rbi            Int      @default(0)
  balls          Int      @default(0)
  strikes        Int      @default(0)
  outs           Int      @default(0)
  createdAt      DateTime @default(now())
  runnersOn      Int      @default(0)
  outsAtStart    Int      @default(0)
  // Baserunner Snapshots (Pre-Pitch)
  runner1Id       Int?     // Player on 1st
  runner2Id       Int?     // Player on 2nd
  runner3Id       Int?     // Player on 3rd
  
  // Scoring Data (Post-Pitch)
  scorerIds       String?  // IDs of players who actually crossed home
}

model LineupEntry {
  id           Int     @id @default(autoincrement())
  gameId       Int
  game         Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId       Int
  team         Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId     Int
  player       Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  battingOrder Int
  isPitcher    Boolean @default(false)
  position     String  @default("Fielder")
}

model ManualStatLine {
  id        Int      @id @default(autoincrement())
  gameId    Int
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  position  String?  @default("F") 

  // Hitting Stats
  pa        Int      @default(0)
  ab        Int      @default(0)
  h         Int      @default(0)
  d2b       Int      @default(0)
  d3b       Int      @default(0)
  hr        Int      @default(0)
  rbi       Int      @default(0)
  r         Int      @default(0)
  bb        Int      @default(0)
  k         Int      @default(0)

  // Pitching Stats
  ip        Float    @default(0.0)
  ph        Int      @default(0)
  pr        Int      @default(0)
  per       Int      @default(0)
  pbb       Int      @default(0)
  pk        Int      @default(0)
  phr       Int      @default(0) // Pitching Home Runs Allowed
  win       Boolean  @default(false)
  loss      Boolean  @default(false)
  save      Boolean  @default(false)
}

model HistoricalStat {
  id        Int    @id @default(autoincrement())
  playerId  Int
  player    Player @relation(fields: [playerId], references: [id])
  season    String 
  leagueId  Int
  hits      Int
  atBats    Int
  homeRuns  Int
  wins      Int
  eras      Float
}
