generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- AUTH & ADMIN MODELS ---

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  name        String?
  roleLevel   Int      @default(1)
  leagueId    Int?
  league      League?  @relation(fields: [leagueId], references: [id])
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model League {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  fullName    String
  location    String?
  description String?
  isActive    Boolean  @default(true) // New field for archiving
  seasons     Season[]
  teams       Team[]
  users       User[]
  createdAt   DateTime @default(now())
}

// --- CORE GAME MODELS ---

model Season {
  id                Int      @id @default(autoincrement())
  name              String
  leagueId          Int
  league            League   @relation(fields: [leagueId], references: [id])
  
  inningsPerGame    Int      @default(4)
  eraStandard       Int      @default(4)
  balls             Int      @default(4)
  strikes           Int      @default(3)
  outs              Int      @default(3)
  isSpeedRestricted Boolean  @default(false)
  isBaserunning     Boolean  @default(true)
  cleanHitRule      Boolean  @default(true)
  ghostRunner       Boolean  @default(false)
  mercyRule         Int      @default(10)
  dpWithoutRunners  Boolean  @default(false)
  dpKeepsRunners    Boolean  @default(false)
  
  games             Game[]
  teams             Team[]   
  rosterSlots       RosterSlot[]
  createdAt         DateTime @default(now())
}

model Team {
  id            Int           @id @default(autoincrement())
  name          String
  leagueId      Int
  league        League        @relation(fields: [leagueId], references: [id])
  
  // Teams now find players through the RosterSlot join table
  rosterSlots   RosterSlot[]
  
  homeGames     Game[]        @relation("HomeTeam")
  awayGames     Game[]        @relation("AwayTeam")
  lineupEntries LineupEntry[]
  
  seasonId      Int?
  season        Season?       @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@unique([name, leagueId])
}

model Player {
  id            Int           @id @default(autoincrement())
  name          String
  
  // A player can have many roster spots (contracts)
  rosterSlots   RosterSlot[]
  
  atBats        AtBat[]       @relation("Batter")
  pitches       AtBat[]       @relation("Pitcher")
  lineupEntries LineupEntry[]
}

// The "Join Table" that connects Players to Teams for a specific Season
model RosterSlot {
  id        Int    @id @default(autoincrement())
  playerId  Int
  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  teamId    Int
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  seasonId  Int
  season    Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  // Ensures a player isn't added to the same team/season combo twice
  @@unique([playerId, teamId, seasonId])
}

model Game {
  id                   Int           @id @default(autoincrement())
  homeTeamId           Int
  homeTeam             Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId           Int
  awayTeam             Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  
  status               String        @default("UPCOMING") 
  homeScore            Int           @default(0)
  awayScore            Int           @default(0)
  currentInning        Int           @default(1)
  isTopInning          Boolean       @default(true)
  
  currentHomePitcherId Int?
  currentAwayPitcherId Int?

  atBats               AtBat[]
  lineups              LineupEntry[]
  scheduledAt          DateTime      @default(now())
  createdAt            DateTime      @default(now())

  seasonId             Int?
  season               Season?       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
}

model AtBat {
  id         Int      @id @default(autoincrement())
  gameId     Int
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  batterId   Int
  batter     Player   @relation("Batter", fields: [batterId], references: [id])
  pitcherId  Int
  pitcher    Player   @relation("Pitcher", fields: [pitcherId], references: [id])
  
  inning     Int      @default(1)
  result     String?  
  runsScored Int      @default(0)
  rbi        Int      @default(0)
  balls      Int      @default(0)
  strikes    Int      @default(0)
  outs       Int      @default(0)
  createdAt  DateTime @default(now())
}

model LineupEntry {
  id           Int     @id @default(autoincrement())
  gameId       Int
  game         Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId     Int
  player       Player  @relation(fields: [playerId], references: [id])
  teamId       Int
  team         Team    @relation(fields: [teamId], references: [id])
  battingOrder Int
  isPitcher    Boolean @default(false)
}